# process data
## species specific data
sd1 <- speciesData |>
dplyr::filter(taxon == j)
# recombine for a
if (j == "Vitis cinerea") {
sd1 <- speciesData |>
dplyr::filter(
taxon %in%
c(
"Vitis cinerea",
"Vitis cinerea var. cinerea",
"Vitis cinerea var. tomentosa"
)
) |>
dplyr::mutate(
taxon = "Vitis cinerea"
)
}
if (j == "Vitis aestivalis") {
sd1 <- speciesData |>
dplyr::filter(
taxon %in%
c(
"Vitis aestivalis",
"Vitis aestivalis var. aestivalis",
"Vitis aestivalis var. bicolor"
)
) |>
dplyr::mutate(
taxon = "Vitis aestivalis"
)
}
