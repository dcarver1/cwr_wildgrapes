print(i)
file.copy(i, folder, overwrite = TRUE)
}
library(dplyr)
library(readr)
library(stringr)
library(tidyr)
# 1. Load the Datasets ----------------------------------------------------
# Update paths if necessary to match your working directory
taxa_stats <- read_csv("~/trueNAS/work/cwr_wildgrapes/temp/slf/slfCountiesPerTaxa.csv")
county_join <- read_csv("~/trueNAS/work/cwr_wildgrapes/temp/slf/slf_vitis_countyJoin.csv")
regions <- tibble(
stateFIPS = c(
# Western
"US02", "US04", "US06", "US08", "US15", "US16", "US30", "US32", "US35", "US41", "US49", "US53", "US56",
# Southern
"US01", "US05", "US12", "US13", "US21", "US22", "US28", "US37", "US40", "US45", "US47", "US48", "US51", "US54",
# Northern/Eastern (Midwest + Northeast)
"US09", "US10", "US11", "US17", "US18", "US19", "US20", "US23", "US24", "US25", "US26", "US27", "US29",
"US31", "US33", "US34", "US36", "US38", "US39", "US42", "US44", "US46", "US50", "US55"
),
Region_Name = c(
rep("Western", 13),
rep("Southern", 14),
rep("Northern/Eastern", 24)
)
)
species_ranges <- county_join %>%
filter(type == "vitis", !is.na(taxa)) %>%
# Clean up the R vector string format if present (e.g., 'c("Species A", "Species B")')
mutate(
taxa_clean = str_remove_all(taxa, 'c\\(|\\)|"'),
taxa_clean = str_replace_all(taxa_clean, ", ", ",")
) %>%
# Expand rows so each species has its own row per county
separate_rows(taxa_clean, sep = ",") %>%
# Join with region definitions
left_join(regions, by = "stateFIPS") %>%
group_by(taxa_clean) %>%
summarise(
unique_states = n_distinct(stateFIPS),
regions_present = paste(sort(unique(na.omit(Region_Name))), collapse = ", "),
# Calculate the proportion of counties in each region to determine the dominant range
pct_West = mean(Region_Name == "Western", na.rm = TRUE),
pct_South = mean(Region_Name == "Southern", na.rm = TRUE),
pct_NorthEast = mean(Region_Name == "Northern/Eastern", na.rm = TRUE)
) %>%
mutate(
# Logic for Generalized Range Classification
Range_Estimate = case_when(
unique_states >= 20 ~ "Widespread",
pct_West > 0.8 ~ "Western",
pct_South > 0.6 ~ "Southern",
pct_NorthEast > 0.6 ~ "Northern/Eastern",
# Overlap cases
pct_South > 0.3 & pct_NorthEast > 0.3 ~ "Eastern", # Broad Eastern US
TRUE ~ "Widespread" # Fallback
)
) %>%
select(taxon = taxa_clean, Range_Estimate)
final_table <- taxa_stats %>%
# Join with the range estimate
left_join(species_ranges, by = "taxon") %>%
mutate(
# Calculate Percent Overlap
Percent_Overlap = (slfCounties / totalCounties) * 100,
# Round for display
Percent_Overlap = round(Percent_Overlap, 2)
) %>%
# Select and Rename columns for the final report
select(
Taxon = taxon,
`Total Counties` = totalCounties,
`Counties with SLF` = slfCounties,
`Percent Overlap (%)` = Percent_Overlap,
`Estimated Range` = Range_Estimate
) %>%
arrange(desc(`Percent Overlap (%)`))
# 5. View and Export ------------------------------------------------------
print(final_table)
library(dplyr)
library(readr)
library(stringr)
library(tidyr)
# 1. Load the Datasets ----------------------------------------------------
# Update paths if necessary to match your working directory
taxa_stats <- read_csv("~/trueNAS/work/cwr_wildgrapes/temp/slf/slfCountiesPerTaxa.csv")
county_join <- read_csv("~/trueNAS/work/cwr_wildgrapes/temp/slf/slf_vitis_countyJoin.csv")
# 2. Define Region Lookups (by State FIPS) -------------------------------
# Note: Adjust FIPS codes or mapping logic as needed for your specific definitions
# US01=AL, US04=AZ, US06=CA, etc.
# This is a generalized mapping for the code.
regions <- tibble(
stateFIPS = c(
# Western
"US02", "US04", "US06", "US08", "US15", "US16", "US30", "US32", "US35", "US41", "US49", "US53", "US56",
# Southern
"US01", "US05", "US12", "US13", "US21", "US22", "US28", "US37", "US40", "US45", "US47", "US48", "US51", "US54",
# Northern/Eastern (Midwest + Northeast)
"US09", "US10", "US11", "US17", "US18", "US19", "US20", "US23", "US24", "US25", "US26", "US27", "US29",
"US31", "US33", "US34", "US36", "US38", "US39", "US42", "US44", "US46", "US50", "US55"
),
Region_Name = c(
rep("Western", 13),
rep("Southern", 14),
rep("Northern/Eastern", 24)
)
)
# 3. Process County Data to Determine Ranges -----------------------------
# We need to expand the county list to find which states each species is in.
species_ranges <- county_join %>%
filter(type == "vitis", !is.na(taxa)) %>%
# Clean up the R vector string format if present (e.g., 'c("Species A", "Species B")')
mutate(
taxa_clean = str_remove_all(taxa, 'c\\(|\\)|"'),
taxa_clean = str_replace_all(taxa_clean, ", ", ",")
) %>%
# Expand rows so each species has its own row per county
separate_rows(taxa_clean, sep = ",") %>%
# Join with region definitions
left_join(regions, by = "stateFIPS") %>%
group_by(taxa_clean) %>%
summarise(
unique_states = n_distinct(stateFIPS),
regions_present = paste(sort(unique(na.omit(Region_Name))), collapse = ", "),
# Calculate the proportion of counties in each region to determine the dominant range
pct_West = mean(Region_Name == "Western", na.rm = TRUE),
pct_South = mean(Region_Name == "Southern", na.rm = TRUE),
pct_NorthEast = mean(Region_Name == "Northern/Eastern", na.rm = TRUE)
) %>%
mutate(
# Logic for Generalized Range Classification
Range_Estimate = case_when(
unique_states >= 20 ~ "Widespread",
pct_West > 0.8 ~ "Western",
pct_South > 0.6 ~ "Southern",
pct_NorthEast > 0.6 ~ "Northern/Eastern",
# Overlap cases
pct_South > 0.3 & pct_NorthEast > 0.3 ~ "Eastern", # Broad Eastern US
TRUE ~ "Widespread" # Fallback
)
) %>%
select(taxon = taxa_clean, Range_Estimate)
# 4. Create Final Summary Table -------------------------------------------
final_table <- taxa_stats %>%
# Join with the range estimate
left_join(species_ranges, by = "taxon") %>%
mutate(
# Calculate Percent Overlap
Percent_Overlap = (slfCounties / totalCounties) * 100,
# Round for display
Percent_Overlap = round(Percent_Overlap, 2)
) %>%
# Select and Rename columns for the final report
select(
Taxon = taxon,
`Total Counties` = totalCounties,
`Counties with SLF` = slfCounties,
`Percent Overlap (%)` = Percent_Overlap,
`Estimated Range` = Range_Estimate
) %>%
arrange(desc(`Percent Overlap (%)`))
# 5. View and Export ------------------------------------------------------
print(final_table)
species_ranges
library(dplyr)
library(readr)
library(stringr)
library(tidyr)
# 1. Load the Datasets ----------------------------------------------------
# Update paths if necessary to match your working directory
taxa_stats <- read_csv("~/trueNAS/work/cwr_wildgrapes/temp/slf/slfCountiesPerTaxa.csv")
# 2. Define Range Estimates Manually --------------------------------------
# Since the county join file is missing taxa names, we assign ranges
# based on the known distribution of these specific Vitis taxa.
taxa_ranges <- taxa_stats %>%
mutate(
Range_Estimate = case_when(
# Western Species (Pacific/Southwest)
str_detect(taxon, "californica|arizonica|girdiana") ~ "Western",
# Northern/Eastern Species (Cool Climate/New England)
str_detect(taxon, "novae-angliae|labrusca") ~ "Northern/Eastern",
# Southern Species (Texas, Florida, Southeast)
str_detect(taxon, "rotundifolia|mustangensis|shuttleworthii|berlandieri|monticola|acerifolia|lincecumii|rufotomentosa|rupestris|champinii|doaniana|baileyana") ~ "Southern",
# Widespread Species (Broad Eastern US Distribution)
str_detect(taxon, "aestivalis|riparia|vulpina|cinerea") ~ "Widespread",
# Fallback for any others
TRUE ~ "Widespread"
)
)
taxa_ranges
# Export to CSV
write_csv(final_table, "SLF_Species_Impact_Summary.csv")
# 4. View and Export ------------------------------------------------------
print(final_table)
# Export to CSV
write_csv(final_table, "~/trueNAS/work/cwr_wildgrapes/temp/SLF_Species_Impact_Summary.csv")
# 4. View and Export ------------------------------------------------------
print(final_table)
# 3. Create Final Summary Table -------------------------------------------
final_table <- taxa_ranges %>%
mutate(
# Calculate Percent Overlap
# Ensure totalCounties is not zero to avoid division by zero
Percent_Overlap = if_else(totalCounties > 0, (slfCounties / totalCounties) * 100, 0),
# Round to 2 decimal places
Percent_Overlap = round(Percent_Overlap, 2)
) %>%
# Rename columns to match desired output
select(
Taxon = taxon,
`Total Counties` = totalCounties,
`Counties with SLF` = slfCounties,
`Percent Overlap (%)` = Percent_Overlap,
`Estimated Range` = Range_Estimate
) %>%
# Sort by highest overlap first
arrange(desc(`Percent Overlap (%)`))
# 4. View and Export ------------------------------------------------------
print(final_table)
# Export to CSV
write_csv(final_table, "~/trueNAS/work/cwr_wildgrapes/temp/slf/SLF_Species_Impact_Summary.csv")
